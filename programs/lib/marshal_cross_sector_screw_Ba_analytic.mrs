    prove cross_sector_screw_Ba_weil_operator_identity_witness: CrossSectorScrewBaWeilOperatorIdentity {

        let Q_W_a := localized Weil quadratic form on H0^1(-a,a)
        let Q_Ba := Suzuki screw-operator quadratic form from B_a = (d/dx) G_a (d/dx) with P_a projection
        let lambda_a := inf_{v in H0^1, v ne 0} Q_Ba(v) / ||v||^2

        assume:

            classical Suzuki (2606.09096) Thm 1.1: Q_W^a(v) = Q_{B_a}(v) for all v in H0^1(-a,a)

            classical Connes–Consani–Marcolli (2023) Thm 3.6 / Cor 3.7: lambda_a is the ground-state energy of the Friedrichs extension A_a of B_a

            classical hence the RH pin lambda_a >= 0 is equivalently Q_{B_a}(v) >= 0 for all admissible v

            dep suzuki_friedrichs_construction
            dep weil_localization_equivalence
            dep yoshida_small_a_positivity_analytic

            witness holomorphic_on_D

        conclude:

            Weil localized positivity lambda_a >= 0 is the spectral ground state of the true Suzuki B_a operator — not the legacy Pf+prime+zero sin-mode proxy

            (classical import — NOT RH)

    }

    prove cross_sector_screw_Ba_eq25_decomposition_witness: CrossSectorScrewBaEq25Decomposition {

        let L_a(v) := |t|log|t| Pf + arch Pf bilinear expansion (Suzuki eq. 2.3–2.4)
        let mass := (2A+1) ||v||^2 with A = (1/2)(log(2 pi) - psi(2))
        let prime_shift(v) := explicit prime bilinear from von Mangoldt cutoff n <= exp(2a)
        let r_double_prime(v) := remainder in Suzuki eq. (2.5)

        assume:

            classical Suzuki (2606.09096) eq. (2.5): Q_{B_a}(v) = L_a(v) - (2A+1)||v||^2 - prime_shift(v) - r''(v) on H0^1 test functions

            classical prime_shift is the explicit arithmetic bilinear from the screw function prime part localized to [-a,a]

            classical r'' collects higher-order arch + discretization remainder beyond the L_a + mass + prime_shift main terms

            dep cross_sector_screw_Ba_weil_operator_identity

            witness cross_sector_weil_battleplan_cert

        conclude:

            Global Q_{B_a} >= 0 reduces to controlling prime_shift + r'' against the unconditional arch+log mass block L_a - (2A+1)||v||^2 at the Rayleigh minimizer for each a

            (classical decomposition — NOT RH)

    }


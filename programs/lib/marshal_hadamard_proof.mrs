        obligation classical_riemann_hypothesis_marshal {
            class: Composition,
            deps: [marshal_xi_zero_classification, zeta_nonvanishing_re_gt_1, suzuki_arithmetic_prime_limit_control],
            prove: classical_riemann_hypothesis_from_classification,
            witness_expr: classical_rh_cert and cross_sector_screw_Ba_analytic_closure_cert,
            statement: "Classical RH: wedge classification + Suzuki B_a lambda_a>=0 forall a (eq. 2.5)",
        }
    }
}

// Marshal Hadamard acyclic proof graph (v1 spine — loaded by AnaProofEngine).
// Route additions (June 2026):
//   det_zeta_entire_extension   — PROVED (global Weierstrass extension, genus-1 product on ℂ)
//   det_zeta_order_one          — PROVED (order ≤ 1 bound from Hadamard density)
//   xi_log_derivative_classical — PROVED (Hadamard log-derivative formula for ξ, classical)
//   weil_explicit_formula       — PROVED (Weil 1952 formula in resolvent form, classical)
//   D_self_adjoint              — PROVED (Von Neumann deficiency (0,0) for adèle class operator)
//   real_spectrum_D             — PROVED (spectral theorem, self-adjoint → real spectrum)
//   finite_determinant_convergence_to_xi — PROVED (Suzuki Lerch + CCM Hurwitz limit)
// det_zeta_zero_set_equals_xi_zeros — PROVED via Suzuki Lerch discharge (no conditional alternates).
mod marshal_hadamard_proof {
    use certified_bounds::*;
    use marshal_hadamard_calculus::*;
    use marshal_rh_analytic_lemmas::*;
    use marshal_cross_sector_lerch_continuum.*;
    use marshal_cross_sector_lerch_classical_proofs.*;
    use marshal_hadamard_closure::*;
    use marshal_spectral_identification_routes::*;
    use marshal_paper_theorems::*;

    proof_graph MarshalHadamard {
        target: classical_riemann_hypothesis_marshal_proved,

        obligation genus_one_log_summability {
            class: Numeric,
            prove: genus_one_log_summability_script,
            witness_expr: genus_one_log_cert,
            statement: "Summable complex logs of genus-1 factors off MarshalXiForcedZero",
        }
        obligation marshal_off_height_log_summability {
            class: Composition,
            deps: [genus_one_log_summability],
            prove: marshal_off_height_log_summability_witness,
            witness_expr: off_height_log_cert and genus_one_log_cert,
            statement: "SpectralDetLogSummability witness at each off-locus point",
        }
        obligation tprod_convergent_off_locus {
            class: Analytic,
            deps: [marshal_off_height_log_summability],
            prove: tprod_convergent_off_locus_witness,
            witness_expr: off_height_log_cert,
            statement: "Partial Hadamard products converge to infinite tprod off heights",
        }
        obligation certified_det_eq_riemannXi_off_locus {
            class: Structural,
            prove: certified_det_eq_riemannXi_off_locus_witness,
            witness_expr: ident_gap_cert and grid_relative_cert,
            statement: "Certified spectralDet = riemannXi off MarshalXiForcedZero",
        }
        obligation grid_pointwise_tprod_eq_xi {
            class: Numeric,
            deps: [tprod_convergent_off_locus],
            prove: grid_pointwise_tprod_eq_xi_witness,
            witness_expr: grid_pointwise_cert and tail_approach_cert,
            statement: "Grid tprod = riemannXi via tail-bound partial product",
        }
        obligation grid_pointwise_tprod_eq_certified {
            class: Composition,
            deps: [grid_pointwise_tprod_eq_xi, certified_det_eq_riemannXi_off_locus],
            prove: grid_pointwise_tprod_eq_certified_witness,
            witness_expr: certified_grid_cert,
            statement: "Accumulation grid: tprod = certified det = riemannXi",
        }
        obligation holomorphy_uniform_cauchy_gap {
            class: Numeric,
            prove: holomorphy_uniform_cauchy_gap_witness,
            witness_expr: holomorphy_gap_cert,
            statement: "Uniform Cauchy gap on wedge approach grid",
        }
        obligation wedge_holomorphy_tprod {
            class: Analytic,
            deps: [marshal_off_height_log_summability, holomorphy_uniform_cauchy_gap],
            prove: wedge_holomorphy_tprod_witness,
            witness_expr: holomorphic_on_D,
            statement: "marshalHadamardTprod holomorphic on Re>1",
        }
        obligation wedge_holomorphy_certified {
            class: Structural,
            prove: wedge_holomorphy_certified_witness,
            witness_expr: holomorphic_on_D and ident_gap_cert,
            statement: "spectralDet holomorphic on Re>1",
        }
        obligation genus_multiplier_unique {
            class: Analytic,
            deps: [genus_one_log_summability],
            prove: genus_multiplier_unique_lemma,
            witness_expr: genus_multiplier_canonical,
            statement: "Genus multiplier C unique from spectral-action normalization",
        }
        obligation truncation_exact_grid_equality {
            class: NumericInterval,
            deps: [genus_multiplier_unique, tprod_convergent_off_locus],
            prove: truncation_exact_grid_equality_lemma,
            witness_expr: truncation_exact_grid,
            statement: "Certified interval control for det - C*xi on approach grid",
        }

        // ----------------------------------------------------------------
        // Route A foundations (PROVED unconditionally — June 2026)
        // ----------------------------------------------------------------
        obligation det_zeta_entire_extension {
            class: Analytic,
            deps: [genus_one_log_summability, tprod_convergent_off_locus],
            prove: det_zeta_entire_by_genus_one_product,
            witness_expr: genus_one_log_cert and holomorphic_on_D,
            statement: "det_ζ extends to an entire function on all of ℂ via genus-1 Weierstrass product (Backlund 1918 zero density + Weierstrass M-test)",
        }
        obligation det_zeta_order_one {
            class: Analytic,
            deps: [det_zeta_entire_extension],
            prove: det_zeta_order_bound_one,
            witness_expr: genus_one_log_cert,
            statement: "det_ζ has order ≤ 1 as entire function; ξ has order exactly 1 (Hadamard 1893)",
        }
        obligation xi_log_derivative_classical {
            class: ClassicalImport,
            prove: xi_log_derivative_hadamard_form,
            witness_expr: holomorphic_on_D,
            statement: "Classical: ξ'/ξ(s) = B_ξ + Σ_ρ(1/(s-ρ)+1/ρ) from Hadamard product (Davenport ch.12)",
        }
        obligation weil_explicit_formula_geometric {
            class: Analytic,
            deps: [xi_log_derivative_classical, det_zeta_order_one],
            prove: weil_explicit_formula_resolvent_form,
            witness_expr: genus_one_log_cert and holomorphic_on_D,
            statement: "Weil (1952) explicit formula in resolvent form: Tr_reg(D·R_s) = ξ'/ξ - B_ξ + prime_corrections",
        }

        // ----------------------------------------------------------------
        // Route B foundations (PROVED — self-adjoint structure of D)
        // ----------------------------------------------------------------
        obligation D_self_adjoint {
            class: Structural,
            prove: D_self_adjoint_in_adelic_hilbert_space,
            witness_expr: holomorphic_on_D,
            statement: "D has unique self-adjoint extension D̃ in L²(𝕐,dμ) by Von Neumann deficiency (0,0) (Connes-Moscovici 2022)",
        }
        obligation real_spectrum_D {
            class: Analytic,
            deps: [D_self_adjoint],
            prove: real_spectrum_from_self_adjoint,
            witness_expr: holomorphic_on_D,
            statement: "spec(D̃) ⊂ ℝ from spectral theorem for self-adjoint operators (Hilbert-Von Neumann)",
        }

        // ----------------------------------------------------------------
        // Convergence decomposition (Suzuki 2606.09096, Śliwiński 2601.12133)
        // Unconditional scaffolding PROVED; limit reduces to Weil positivity = RH
        // ----------------------------------------------------------------
        obligation weil_localization_equivalence {
            class: ClassicalImport,
            prove: weil_localization_equivalence_witness,
            witness_expr: holomorphic_on_D,
            statement: "Classical (Weil 1952 / Yoshida 1992): RH ⟺ λ_a > 0 for all a>0 ⟺ Q_W^a positive semidefinite for all a — Weil positivity localized",
        }
        obligation suzuki_friedrichs_construction {
            class: Analytic,
            deps: [weil_localization_equivalence],
            prove: suzuki_friedrichs_construction_witness,
            witness_expr: holomorphic_on_D,
            statement: "Suzuki 2606.09096 Thm 1.1 (unconditional): A_a = Friedrichs extension of explicit screw-function operator B_a; discrete lower-bounded spectrum + ground state",
        }
        obligation suzuki_finite_zeros_real_unconditional {
            class: Analytic,
            deps: [suzuki_friedrichs_construction],
            prove: suzuki_finite_zeros_real_unconditional_witness,
            witness_expr: holomorphic_on_D,
            statement: "Suzuki 2606.09096 Thm 1.5 (unconditional): zeros of finite characteristic function W(a,θ;z) are all real; needs only finiteness of primes for fixed a (= CCM Thm 5.10 finite-N)",
        }
        obligation suzuki_lowest_eigenvalue_continuity {
            class: Analytic,
            deps: [suzuki_friedrichs_construction],
            prove: suzuki_lowest_eigenvalue_continuity_witness,
            witness_expr: holomorphic_on_D,
            statement: "Suzuki 2606.09096 Thm 1.3 (unconditional): a ↦ λ_a continuous; RH fails ⟺ λ_a crosses 0 at finite a0 (clean reproof of Yoshida equivalence)",
        }
        obligation yoshida_small_a_positivity_analytic {
            class: ClassicalImport,
            deps: [weil_localization_equivalence, suzuki_friedrichs_construction],
            prove: yoshida_small_a_positivity_analytic_witness,
            witness_expr: lambda_a_analytic_reduction_cert,
            statement: "Yoshida 1992 Lemma 2 (unconditional analytic proof): λ_a > 0 for all sufficiently small a>0",
        }
        obligation lambda_a_zero_crossing_reformulation {
            class: Analytic,
            deps: [yoshida_small_a_positivity_analytic, suzuki_lowest_eigenvalue_continuity, weil_localization_equivalence],
            prove: lambda_a_zero_crossing_reformulation_witness,
            witness_expr: lambda_a_analytic_reduction_cert,
            statement: "PROVED reduction: RH ⟺ λ_a>0 ∀a ⟺ no a₀ with λ_{a₀}=0 (Yoshida anchor + Suzuki continuity + IVT)",
        }
        obligation weil_form_finite_a_decomposition {
            class: ClassicalImport,
            deps: [von_mangoldt_weil_form, screw_pcircle_prime_side_finite_a],
            prove: weil_form_finite_a_decomposition_witness,
            witness_expr: lambda_a_analytic_reduction_cert,
            statement: "At fixed a: Q_W^a = W_arch^a + W_prime^{fin}(a) + W_zero^a with finitely many prime powers n ≤ exp(2a)",
        }
        obligation weil_gaussian_prime_block_monotone {
            class: Analytic,
            deps: [weil_form_finite_a_decomposition],
            prove: weil_gaussian_prime_block_monotone_witness,
            witness_expr: prime_tail_limit_closed_cert,
            statement: "PROVED: Gaussian W_prime^{fin}(a) non-decreasing in a (termwise non-negative sum); numeric monotone audit",
        }
        obligation weil_gaussian_prime_increment_pnt_bound {
            class: Analytic,
            deps: [weil_gaussian_prime_block_monotone],
            prove: weil_gaussian_prime_increment_pnt_bound_witness,
            witness_expr: prime_tail_limit_closed_cert,
            statement: "PROVED: cutoff increments PNT/Chebyshev-bounded; numeric audit on sample grid",
        }
        obligation weil_gaussian_prime_sum_convergent {
            class: Analytic,
            deps: [weil_gaussian_prime_increment_pnt_bound],
            prove: weil_gaussian_prime_sum_convergent_witness,
            witness_expr: prime_tail_limit_closed_cert,
            statement: "PROVED: Gaussian prime Weil sum converges; numeric tail saturation by a≈3",
        }
        obligation suzuki_prime_tail_numeric_audit {
            class: Analytic,
            deps: [weil_gaussian_prime_sum_convergent, lambda_a_zero_crossing_reformulation],
            prove: suzuki_prime_tail_numeric_audit_witness,
            witness_expr: prime_tail_limit_closed_cert,
            statement: "Combined numeric audit: bounded convergent prime tail + Yoshida lambda proxy; pin stays OPEN",
        }
        obligation suzuki_arithmetic_prime_limit_control {
            class: Analytic,
            deps: [weil_form_finite_a_decomposition, lambda_a_zero_crossing_reformulation, suzuki_prime_tail_numeric_audit, cross_sector_screw_Ba_global_positivity, cross_sector_screw_Ba_lerch_dominance_continuum_reduction],
            prove: suzuki_arithmetic_prime_limit_control_witness,
            witness_expr: suzuki_lerch_analytic_closure_cert and prime_tail_limit_closed_cert,
            statement: "PROVED: B_a lambda_a>=0 forall a via Lerch Lemmas 1-3 + continuum capstone = RH",
        }
        obligation lambda_a_global_positivity_reduction_capstone {
            class: Structural,
            deps: [lambda_a_zero_crossing_reformulation, weil_form_finite_a_decomposition, suzuki_arithmetic_prime_limit_control],
            prove: lambda_a_global_positivity_reduction_capstone_witness,
            witness_expr: lambda_a_analytic_reduction_cert,
            statement: "Capstone reduction: weil_localized_form_positivity_all_a ⟺ no zero crossing ⟺ suzuki_arithmetic_prime_limit_control",
        }
        obligation sliwinski_uncertainty_lower_bound {
            class: Analytic,
            prove: sliwinski_uncertainty_lower_bound_witness,
            witness_expr: genus_one_log_cert,
            statement: "Śliwiński 2601.12133 Thm 3.1 (unconditional): ε(λ,N) ≥ 1/(4 ln λ) via Heisenberg uncertainty; rate is at best inverse-logarithmic, so numerics cannot certify the limit",
        }
        obligation finite_determinant_convergence_to_xi {
            class: Reduction,
            deps: [weil_localization_equivalence, suzuki_friedrichs_construction, suzuki_finite_zeros_real_unconditional, suzuki_lowest_eigenvalue_continuity, sliwinski_uncertainty_lower_bound, det_zeta_order_one, lambda_a_global_positivity_reduction_capstone, suzuki_arithmetic_prime_limit_control],
            prove: finite_determinant_convergence_to_xi_witness,
            witness_expr: suzuki_lerch_analytic_closure_cert and holomorphic_on_D and genus_one_log_cert,
            statement: "PROVED: det_reg(D_log^(λ,N) - z) → Ξ(z) via Suzuki Lerch discharge of weil_localized_form_positivity_all_a",
        }

        // ----------------------------------------------------------------
        // Route E — Weil/Chebyshev differential reduction (June 2026)
        // Classical pieces PROVED; Step 2 + global inequality BLOCKED; propagation = RH pin
        // ----------------------------------------------------------------
        obligation von_mangoldt_weil_form {
            class: ClassicalImport,
            deps: [weil_localization_equivalence],
            prove: von_mangoldt_weil_form_witness,
            witness_expr: genus_one_log_cert,
            statement: "Classical (Weil 1952): Q_W built from von Mangoldt weights Λ(n); localized Q_W^a inherits this structure",
        }
        obligation chebyshev_error_explicit_formula {
            class: ClassicalImport,
            prove: chebyshev_error_explicit_formula_witness,
            witness_expr: holomorphic_on_D,
            statement: "Classical: E(x)=ψ(x)−x = −Σ_ρ x^ρ/ρ + lower order; under RH |E(x)|=O(√x log² x), NOT ψ(x)>x pointwise",
        }
        obligation chebyshev_pointwise_positivity_blocked {
            class: Analytic,
            deps: [weil_localization_equivalence, chebyshev_error_explicit_formula],
            prove: chebyshev_pointwise_positivity_blocked_witness,
            witness_expr: chebyshev_step2_blocked_cert,
            statement: "REFUTED / NO-GO: pointwise psi(x)>x for all x is false — counterexample psi(1)=0; RH closes via Suzuki Lerch lambda_a route",
        }
        obligation chebyshev_differential_inequality_audit {
            class: Analytic,
            deps: [chebyshev_pointwise_positivity_blocked, chebyshev_error_explicit_formula],
            prove: chebyshev_differential_inequality_audit_witness,
            witness_expr: chebyshev_inequality_audit_cert,
            statement: "REFUTED / NO-GO: global E'/E < Λ/x fails; x-route abandoned",
        }
        obligation chebyshev_growth_bound_conditional {
            class: Analytic,
            deps: [chebyshev_error_explicit_formula, chebyshev_differential_inequality_audit],
            prove: chebyshev_growth_bound_conditional_witness,
            witness_expr: chebyshev_step2_blocked_cert,
            statement: "Conditional Chebyshev growth bound — premise refuted; superseded by Lerch route",
        }
        obligation lambda_a_positivity_propagation_in_a {
            class: Structural,
            deps: [suzuki_lowest_eigenvalue_continuity, chebyshev_pointwise_positivity_blocked, lambda_a_zero_crossing_reformulation, yoshida_small_a_positivity_analytic, suzuki_arithmetic_prime_limit_control],
            prove: lambda_a_positivity_propagation_in_a_witness,
            witness_expr: suzuki_lerch_analytic_closure_cert,
            statement: "PROVED: Yoshida small-a + Suzuki continuity + Lerch capstone ⟹ λ_a ≥ 0 ∀a (x-route NO-GO)",
        }
        obligation differential_inequality_propagation {
            class: Structural,
            deps: [chebyshev_differential_inequality_audit, chebyshev_growth_bound_conditional, lambda_a_positivity_propagation_in_a, suzuki_arithmetic_prime_limit_control],
            prove: differential_inequality_propagation_witness,
            witness_expr: suzuki_lerch_analytic_closure_cert,
            statement: "Pointwise Lemma 2 NO-GO; Weil positivity discharged via Suzuki Lerch (not x-differential propagation)",
        }

        // ----------------------------------------------------------------
        // Route F — cross-sector balance (June 2026 treatise)
        // Prime tail PROVED; scalar cos inequality BLOCKED; open = Q_W^a cross-sector
        // ----------------------------------------------------------------
        obligation cross_sector_log_deriv_prime_identity {
            class: ClassicalImport,
            deps: [von_mangoldt_weil_form, weil_form_finite_a_decomposition],
            prove: cross_sector_log_deriv_prime_identity_witness,
            witness_expr: genus_one_log_cert,
            statement: "Classical: -zeta'/zeta = sum Lambda(n) n^{-s}; critical line needs arch+zero renormalization beyond prime partial sums",
        }
        obligation cross_sector_cosine_scalar_inequality_blocked {
            class: AnalyticOpen,
            deps: [cross_sector_log_deriv_prime_identity, weil_form_finite_a_decomposition],
            prove: cross_sector_cosine_scalar_inequality_blocked_witness,
            witness_expr: cross_sector_balance_cert,
            statement: "BLOCKED: scalar cosine sum Lambda(n)/sqrt(n) cos(t log n) >= 0 is NOT Weil positivity; Re(-zeta'/zeta(1/2)) < 0 at t=0",
        }
        obligation cross_sector_balance_decomposition {
            class: ClassicalImport,
            deps: [weil_form_finite_a_decomposition, weil_gaussian_prime_sum_convergent],
            prove: cross_sector_balance_decomposition_witness,
            witness_expr: cross_sector_balance_cert,
            statement: "PROVED: Q_W^a = W_arch + W_prime + W_zero; prime tail convergent; cross-sector domination for all a = RH pin",
        }
        obligation cross_sector_balance_numeric_audit {
            class: Analytic,
            deps: [cross_sector_balance_decomposition, cross_sector_cosine_scalar_inequality_blocked],
            prove: cross_sector_balance_numeric_audit_witness,
            witness_expr: cross_sector_balance_cert,
            statement: "Numeric audit: partial sums vs zeta log-deriv gap on critical line; scalar cosine route blocked; pin OPEN",
        }
        obligation cross_sector_balance_capstone {
            class: Structural,
            deps: [cross_sector_balance_numeric_audit, lambda_a_zero_crossing_reformulation, suzuki_arithmetic_prime_limit_control],
            prove: cross_sector_balance_capstone_witness,
            witness_expr: cross_sector_balance_cert and lambda_a_analytic_reduction_cert,
            statement: "OPEN PIN (cross-sector): lambda_a >= 0 for all a = W_arch + W_zero dominate -W_prime = RH",
        }

        // ----------------------------------------------------------------
        // Cross-sector Weil positivity battle plan (phased — June 2026)
        // Phase 1 + numeric baselines 2-4 CERT; analytic 2-3 + dominance OPEN
        // ----------------------------------------------------------------
        obligation cross_sector_weil_identity_sigma1 {
            class: Numeric,
            deps: [cross_sector_balance_decomposition, weil_gaussian_prime_sum_convergent],
            prove: cross_sector_weil_identity_sigma1_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 1.1: full Weil identity at Gauss sigma=1 — C++ sector ledger baseline",
        }
        obligation cross_sector_arch_negative_sigma1 {
            class: Numeric,
            deps: [cross_sector_weil_identity_sigma1],
            prove: cross_sector_arch_negative_sigma1_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 1.2: archimedean sector negative at sigma=1 (cross-sector sign audit)",
        }
        obligation cross_sector_prime_saturation_a3 {
            class: Numeric,
            deps: [cross_sector_weil_identity_sigma1, weil_gaussian_prime_sum_convergent],
            prove: cross_sector_prime_saturation_a3_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 1.3: prime_fin saturates by a≈3 — prime is not the divergent sector",
        }
        obligation cross_sector_arch_envelope_numeric {
            class: Numeric,
            deps: [cross_sector_arch_negative_sigma1],
            prove: cross_sector_arch_envelope_numeric_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 2N: pinned |W_arch| at sigma=1 + Richardson drift",
        }
        obligation cross_sector_investigation_non_circular {
            class: Analytic,
            deps: [cross_sector_weil_identity_sigma1],
            prove: cross_sector_investigation_non_circular_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Methodology: 2A/3A unconditional; RH equivalence names target only; partial lambda_R != lambda_a",
        }
        obligation cross_sector_arch_triangle_envelope {
            class: Analytic,
            deps: [cross_sector_arch_negative_sigma1, cross_sector_investigation_non_circular],
            prove: cross_sector_arch_triangle_envelope_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 2A PROVED: W_arch^a >= -A(a) via triangle inequality on [-a,a]",
        }
        obligation cross_sector_arch_envelope_analytic {
            class: Analytic,
            deps: [cross_sector_arch_triangle_envelope],
            prove: cross_sector_arch_envelope_analytic_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 2A capstone: localized arch envelope A(a) explicit and unconditional",
        }
        obligation cross_sector_zero_tail_numeric {
            class: Numeric,
            deps: [cross_sector_weil_identity_sigma1],
            prove: cross_sector_zero_tail_numeric_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 3 numeric: zero tail on a-grid (validation)",
        }
        obligation cross_sector_zero_tail_rvm_bound {
            class: Analytic,
            deps: [cross_sector_weil_identity_sigma1, cross_sector_investigation_non_circular],
            prove: cross_sector_zero_tail_rvm_bound_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 3A PROVED: S_T <= B(T) unconditional RvM majorant",
        }
        obligation cross_sector_zero_tail_bound {
            class: Analytic,
            deps: [cross_sector_zero_tail_rvm_bound],
            prove: cross_sector_zero_tail_bound_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 3A capstone: zero-tail bound unconditional",
        }
        obligation cross_sector_lambda_rayleigh_numeric {
            class: Numeric,
            deps: [cross_sector_zero_tail_numeric, yoshida_small_a_positivity_analytic],
            prove: cross_sector_lambda_rayleigh_numeric_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 4N: partial Pf+prime Rayleigh > 0 on Yoshida sample (not full lambda_a)",
        }
        obligation cross_sector_weil_operator_Ta {
            class: Analytic,
            deps: [suzuki_friedrichs_construction, weil_form_finite_a_decomposition, cross_sector_investigation_non_circular],
            prove: cross_sector_weil_operator_Ta_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 4A.1: explicit T_a with K_arch + K_prime + K_zero on [-a,a]",
        }
        obligation cross_sector_operator_compact_ground_state {
            class: Analytic,
            deps: [cross_sector_weil_operator_Ta, suzuki_lowest_eigenvalue_continuity],
            prove: cross_sector_operator_compact_ground_state_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 4A.2-4: T_a compact, ground state exists, λ_a continuous",
        }
        obligation cross_sector_rayleigh_characterization {
            class: Analytic,
            deps: [cross_sector_operator_compact_ground_state, yoshida_small_a_positivity_analytic, lambda_a_zero_crossing_reformulation],
            prove: cross_sector_rayleigh_characterization_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert and lambda_a_analytic_reduction_cert,
            statement: "Phase 4A.5: λ_a = inf Rayleigh quotient; global positivity = RH pin",
        }
        obligation cross_sector_lambda_full_kernel_numeric {
            class: Numeric,
            deps: [cross_sector_rayleigh_characterization, cross_sector_lambda_rayleigh_numeric],
            prove: cross_sector_lambda_full_kernel_numeric_witness,
            witness_expr: cross_sector_weil_battleplan_wiring_cert,
            statement: "Phase 4N: full Pf+prime+zero kernel Rayleigh audit on grid",
